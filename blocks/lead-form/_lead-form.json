{
  "definitions": [
    {
      "title": "Lead Form",
      "id": "lead-form",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Lead Form",
              "model": "lead-form",
              "filter": "lead-form"
            }
          }
        }
      }
    },
    {
      "title": "Form Field",
      "id": "form-field",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "Form Field",
              "model": "form-field"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "lead-form",
      "fields": [
        {
          "component": "reference",
          "valueType": "string",
          "name": "productImage",
          "label": "Product Image",
          "required": true
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "productImageAlt",
          "label": "Product Image Alt Text"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "productName",
          "label": "Product Name",
          "required": true
        },
        {
          "component": "richtext",
          "valueType": "string",
          "name": "benefits",
          "label": "Benefits (one per line)",
          "description": "Separate each benefit with a line break"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "apiEndpoint",
          "label": "API Endpoint URL",
          "required": true,
          "description": "Full URL where form data will be POSTed as JSON"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "successMessage",
          "label": "Success Message",
          "description": "Message shown after successful submission"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "failureMessage",
          "label": "Failure Message",
          "description": "Message shown when submission fails"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "buttonText",
          "label": "Submit Button Text"
        },
        {
          "component": "richtext",
          "valueType": "string",
          "name": "privacyText",
          "label": "Privacy / Consent Text",
          "description": "Shown with a checkbox above the submit button. Supports links."
        }
      ]
    },
    {
      "id": "form-field",
      "fields": [
        {
          "component": "select",
          "valueType": "string",
          "name": "fieldType",
          "label": "Field Type",
          "required": true,
          "options": [
            { "name": "Text", "value": "text" },
            { "name": "Email", "value": "email" },
            { "name": "Phone", "value": "phone" },
            { "name": "Date", "value": "date" },
            { "name": "Dropdown", "value": "select" },
            { "name": "Toggle (Yes/No or similar)", "value": "toggle" }
          ]
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "fieldLabel",
          "label": "Field Label",
          "required": true
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "placeholder",
          "label": "Placeholder Text"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "options",
          "label": "Options (comma-separated)",
          "description": "For dropdown: option list. For toggle: two values (e.g. Male, Female). For phone: country code (e.g. +91)."
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "required",
          "label": "Required",
          "options": [
            { "name": "Yes", "value": "true" },
            { "name": "No", "value": "false" }
          ]
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "fieldName",
          "label": "Field Name (for API payload)",
          "description": "The key name used when submitting to the API. Auto-derived from label if empty."
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "lead-form",
      "components": [
        "form-field"
      ]
    }
  ]
}
